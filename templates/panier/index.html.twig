{% extends 'base.html.twig' %}

{% block title %}Mon panier{% endblock %}

{% block body %}

    <section class="cart-container">

        <h1 class="cart-title">Mon panier</h1>

        {% if panier|length > 0 %}

            <div class="cart-list">

                {% for item in panier %}
                    <div class="cart-item">

                        <!-- IMAGE -->
                        <div class="cart-image">
                            <img
                                class="product-image"
                                src="{{ item.produit.image
                                ? asset('uploads/' ~ item.produit.image)
                                : asset('images/default.jpg') }}"
                                alt="{{ item.produit.nom }}"
                                data-fallback="{{ asset('images/default.jpg') }}"                            >
                        </div>

                        <!-- INFOS -->
                        <div class="cart-info">
                            <h2>{{ item.produit.nom }}</h2>
                            <p class="cart-category">{{ item.produit.categorie.nom }}</p>
                            <p class="cart-price-unit">
                                {{ (item.produit.prix)|number_format(2, ',', ' ') }} € / unité
                            </p>
                        </div>

                        <!-- QUANTITÉ -->
                        <div class="cart-qty">
                            <a href="{{ path('panier_decrease', {
                                id: item.produit.id,
                                redirect: 'panier'
                            }) }}">➖</a>

                            <span>{{ item.quantite }}</span>

                            <a href="{{ path('panier_add', {
                                id: item.produit.id,
                                redirect: 'panier'
                            }) }}">➕</a>
                        </div>

                        <!-- TOTAL -->
                        <div class="cart-total">
                            {{ ((item.produit.prix * item.quantite))|number_format(2, ',', ' ') }} €
                        </div>

                        <!-- ACTION -->
                        <div class="cart-actions">
                            <a href="{{ path('panier_remove', {
                                id: item.produit.id,
                                redirect: 'panier'
                            }) }}" class="cart-remove">🧺</a>
                        </div>

                    </div>
                {% endfor %}

            </div>

            <div class="cart-footer">

                <div class="cart-total-global">
                    Total : {{ total|number_format(2, ',', ' ') }} €
                </div>

                <form method="post" action="{{ path('panier_valider') }}">
                    <button type="submit" class="btn-validate">
                        Valider mon panier
                    </button>
                </form>

            </div>

        {% else %}
            <p class="cart-empty">Votre panier est vide.</p>
        {% endif %}

    </section>

{% endblock %}
