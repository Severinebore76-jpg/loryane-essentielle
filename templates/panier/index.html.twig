{% extends 'base.html.twig' %}

{% block title %}Mon panier{% endblock %}

{% block body %}

    <h1>Mon panier</h1>

    {% if panier is empty %}
        <p>Votre panier est vide.</p>
    {% else %}

        <table border="1" cellpadding="10">
            <thead>
            <tr>
                <th>Produit</th>
                <th>Prix</th>
                <th>Quantité</th>
                <th>Total</th>
            </tr>
            </thead>
            <tbody>
            {% for item in panier %}
                <tr>
                    <td>{{ item.produit.nom }}</td>
                    <td>{{ item.produit.prix }} €</td>
                    <td>{{ item.quantite }}</td>
                    <td>{{ item.produit.prix * item.quantite }} €</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <h2>Total : {{ total }} €</h2>

    {% endif %}

{% endblock %}
