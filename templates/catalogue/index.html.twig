{% extends 'base.html.twig' %}

{% block title %}Catalogue produits{% endblock %}

{% block body %}

    <!-- HEADER -->
    <section class="catalog-header">
        {% if typePack %}
            <h1>{{ typePack.nom }}</h1>
            <p>{{ typePack.description }}</p>
        {% else %}
            <h1>Tous nos coffrets</h1>
            <p>Explorez l’ensemble de nos univers bien-être.</p>
        {% endif %}
    </section>

    <!-- TOOLBAR -->
    <div class="catalog-toolbar">

            <button id="menu-toggle" class="menu-icon">☰</button>

            <button id="filter-toggle" class="filter-btn">
                Filtres
            </button>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary btn-sm">
                    ← Retour admin
                </a>
                <a href="{{ path('produit_new') }}" class="btn btn-primary">
                    Ajouter un produit
                </a>
            {% endif %}

    </div>

    <!-- MENU PANEL -->
    <div id="menu-panel" class="menu-panel">

        <a href="{{ path('app_produits') }}"
           class="{{ typePack is null ? 'active' }}">
            Tous les packs
        </a>

        {% for pack in typePacks %}
            <a href="{{ path('app_produits', {slug: pack.slug}) }}"
               class="{{ typePack and typePack.id == pack.id ? 'active' }}">
                {{ pack.nom }}
            </a>
        {% endfor %}

    </div>

    <!-- FILTRES PANEL -->
    <div id="filter-panel" class="filter-panel">

        <form method="get">

            <label for="tri">Trier par</label>
            <select id="tri" name="tri" class="filter-select">
                <option value="">Par défaut</option>
                <option value="prix_asc"
                        {% if app.request.query.get('tri') == 'prix_asc' %}selected{% endif %}>
                    Prix croissant
                </option>
                <option value="prix_desc"
                        {% if app.request.query.get('tri') == 'prix_desc' %}selected{% endif %}>
                    Prix décroissant
                </option>
                <option value="nom"
                        {% if app.request.query.get('tri') == 'nom' %}selected{% endif %}>
                    Nom A → Z
                </option>
            </select>

            <button type="submit" class=" btn-primary">
                Appliquer
            </button>

        </form>

    </div>

    <!-- PRODUITS -->
    <div class="products-grid">

        {% for produit in produits %}
            <div class="product-card">

                <a href="{{ path('produit_show', {
                    id: produit.id,
                    categorie: app.request.query.get('categorie')
                }) }}">
                    <img class="img-fallback"
                         src="{{ produit.image
                         ? asset('uploads/' ~ produit.image)
                         : asset('images/produit1.jpg') }}"
                         alt="{{ produit.nom }}">
                </a>

                <div class="product-content">

                    <h2 class="product-title">
                        <a href="{{ path('produit_show', {id: produit.id}) }}">
                            {{ produit.nom }}
                        </a>
                    </h2>

                    <p class="product-category">
                        {{ produit.categorie.nom }}
                    </p>

                    <p class="product-description">
                        {{ produit.description|slice(0, 80) }}...
                    </p>

                    {% if is_granted('ROLE_ADMIN') %}
                        <p class="product-info">Stock : {{ produit.stock }}</p>
                    {% endif %}

                    <div class="product-bottom">

                        <div class="product-price-block">
                        <span class="product-price">
                            {{ produit.prix|number_format(2, ',', ' ') }} €
                        </span>
                            <p class="vat-note">Prix TTC — ajustement au paiement</p>
                        </div>

                        {% if produit.stock > 0 %}
                            <a href="#"
                               class="cart-icon add-to-cart"
                               data-url="{{ path('panier_add', {id: produit.id}) }}">
                                🧺
                            </a>
                        {% else %}
                            <span class="out-of-stock">Rupture</span>
                        {% endif %}

                    </div>

                </div>

                <div class="add-popup">Ajouté au panier ✔</div>

                {% if is_granted('ROLE_ADMIN') %}

                    <div class="product-actions">

                        <a href="{{ path('produit_edit', {id: produit.id}) }}"
                           class="btn btn-primary btn-sm">
                            Modifier
                        </a>

                        <form method="post"
                              action="{{ path('produit_delete', {id: produit.id}) }}"
                              onsubmit="return confirm('Supprimer ce produit ?');"
                              class="inline-form">

                            <input type="hidden"
                                   name="_token"
                                   value="{{ csrf_token('delete' ~ produit.id) }}">

                            <button type="submit"
                                    class="btn btn-danger btn-sm">
                                Supprimer
                            </button>

                        </form>

                    </div>

                {% endif %}

            </div>
        {% endfor %}

    </div>

{% endblock %}
