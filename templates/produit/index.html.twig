{% extends 'base.html.twig' %}

{% block title %}Catalogue produits{% endblock %}

{% block body %}

    <!-- HEADER VISUEL CATÉGORIE -->
    <section class="catalog-header">
        {% if typePack %}
            <h1>{{ typePack.nom }}</h1>
            <p>{{ typePack.description }}</p>
        {% else %}
            <h1>Tous nos coffrets</h1>
            <p>Explorez l’ensemble de nos univers bien-être.</p>
        {% endif %}
    </section>

    <!-- MENU HAMBURGER TYPE PACK -->
    <div class="catalog-menu">

        <button id="menu-toggle" class="menu-icon">☰</button>

        <div id="menu-panel" class="menu-panel">

            <a href="{{ path('app_produits') }}"
               class="{{ typePack is null ? 'active' }}">
                Tous les packs
            </a>

            {% for pack in typePacks %}
                <a href="{{ path('app_produits', {slug: pack.slug}) }}"
                   class="{{ typePack and typePack.id == pack.id ? 'active' }}">
                    {{ pack.nom }}
                </a>
            {% endfor %}

        </div>

    </div>

    <!-- FILTRES -->
    <div class="filters-container">

        <button id="filter-toggle" class="filter-btn">
            Filtres
        </button>

        <div id="filter-panel" class="filter-panel">

            <form method="get">

                <label>Catégorie</label>
                <select name="categorie" class="filter-select">
                    <option value="">Toutes</option>

                    {% for categorie in categories %}
                        <option value="{{ categorie.id }}"
                                {% if app.request.query.get('categorie') == categorie.id %}selected{% endif %}>
                            {{ categorie.nom }}
                        </option>
                    {% endfor %}
                </select>

                <label>Trier par</label>
                <select name="tri" class="filter-select">
                    <option value="">Par défaut</option>
                    <option value="prix_asc"
                            {% if app.request.query.get('tri') == 'prix_asc' %}selected{% endif %}>
                        Prix croissant
                    </option>
                    <option value="prix_desc"
                            {% if app.request.query.get('tri') == 'prix_desc' %}selected{% endif %}>
                        Prix décroissant
                    </option>
                    <option value="nom"
                            {% if app.request.query.get('tri') == 'nom' %}selected{% endif %}>
                        Nom A → Z
                    </option>
                </select>

                <button type="submit" class="btn-validate">
                    Appliquer
                </button>

            </form>

        </div>

    </div>

    <!-- PRODUITS -->
    <div class="products-grid">

        {% for produit in produits %}
            <div class="product-card">

                {% set quantite = panierSession[produit.id] ?? 0 %}

                <a href="{{ path('produit_show', {
                    id: produit.id,
                    categorie: app.request.query.get('categorie')
                }) }}">
                    <img
                        src="{{ produit.image
                        ? asset('uploads/' ~ produit.image)
                        : asset('images/default.jpg') }}"
                        alt="{{ produit.nom }}"
                        onerror="this.src='{{ asset('images/default.jpg') }}'"
                    >
                </a>

                <div class="product-content">

                    <h2 class="product-title">
                        <a href="{{ path('produit_show', {id: produit.id}) }}">
                            {{ produit.nom }}
                        </a>
                    </h2>

                    <p class="product-category">
                        {{ produit.categorie.nom }}
                    </p>

                    <p class="product-description">
                        {{ produit.description|slice(0, 80) }}...
                    </p>

                    {% if is_granted('ROLE_ADMIN') %}
                        <p class="product-info">Stock : {{ produit.stock }}</p>
                    {% endif %}

                    <div class="product-bottom">

                        <div class="product-price-block">
                            <span class="product-price">
                                {{ (produit.prix)|number_format(2, ',', ' ') }} €
                            </span>
                            <p class="vat-note">Prix TTC — ajustement au paiement</p>
                        </div>

                        {% if produit.stock > 0 %}

                            <!-- AJOUT PANIER -->
                            <a href="#"
                               class="cart-icon add-to-cart"
                               data-url="{{ path('panier_add', {id: produit.id}) }}">
                                🧺
                            </a>

                        {% else %}
                            <span class="out-of-stock">Rupture</span>
                        {% endif %}

                    </div>

                </div>

                <div class="add-popup">Ajouté au panier ✔</div>

                {% if is_granted('ROLE_ADMIN') %}
                    <div class="product-actions">
                        <a href="{{ path('produit_edit', {id: produit.id}) }}">Modifier</a>

                        <form method="post"
                              action="{{ path('produit_delete', {id: produit.id}) }}">
                            <input type="hidden"
                                   name="_token"
                                   value="{{ csrf_token('delete' ~ produit.id) }}">
                            <button onclick="return confirm('Supprimer ?')">
                                Supprimer
                            </button>
                        </form>
                    </div>
                {% endif %}

            </div>
        {% endfor %}

    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const btn = document.getElementById("menu-toggle");
            const panel = document.getElementById("menu-panel");

            if (btn) {
                btn.addEventListener("click", function () {
                    panel.style.display = panel.style.display === "block" ? "none" : "block";
                });
            }

            const filterBtn = document.getElementById("filter-toggle");
            const filterPanel = document.getElementById("filter-panel");

            if (filterBtn) {
                filterBtn.addEventListener("click", function () {
                    filterPanel.style.display =
                        filterPanel.style.display === "block" ? "none" : "block";
                });
            }

            document.querySelectorAll(".add-to-cart").forEach(button => {
                button.addEventListener("click", function (e) {
                    e.preventDefault();

                    const url = this.dataset.url;
                    const card = this.closest(".product-card");
                    const popup = card.querySelector(".add-popup");

                    fetch(url)
                        .then(() => {
                            popup.classList.add("show");
                            setTimeout(() => {
                                popup.classList.remove("show");
                            }, 2000);
                        });
                });
            });

        });
    </script>

{% endblock %}
