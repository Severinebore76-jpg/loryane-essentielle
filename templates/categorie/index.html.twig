{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}

    <section class="admin-container">

        <div class="admin-header">

            <h1 class="admin-title">Catégories</h1>

            <div class="admin-actions">
                <a href="{{ path('admin_dashboard') }}" class="btn btn-outline">
                    ← Retour admin
                </a>

                <a href="{{ path('categorie_new') }}" class="btn btn-main">
                    + Ajouter une catégorie
                </a>
            </div>

        </div>

        <div class="admin-grid">

            {% for categorie in categories %}
                <div class="admin-card">

                    <h2>{{ categorie.nom }}</h2>

                    <p class="admin-desc">
                        {{ categorie.description }}
                    </p>

                    <p class="admin-meta">
                        {{ categorie.produits|length }} produit(s)
                    </p>

                    <div class="admin-actions">

                        <a href="{{ path('categorie_edit', {id: categorie.id}) }}"
                           class="btn btn-outline btn-sm">
                            Modifier
                        </a>

                        <form method="post"
                              action="{{ path('categorie_delete', {id: categorie.id}) }}"
                              onsubmit="return confirm('Supprimer cette catégorie ?');">

                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('delete' ~ categorie.id) }}">

                            <button class="btn btn-delete btn-sm">
                                Supprimer
                            </button>

                        </form>

                    </div>

                </div>
            {% else %}
                <p>Aucune catégorie</p>
            {% endfor %}

        </div>

    </section>

{% endblock %}
