{% extends 'base.html.twig' %}

{% block title %}
    À propos
{% endblock %}

{% block body %}

    <!-- HERO -->
    <section class="about-hero">

        <img
            src="{{ asset('images/icone_loryane.png') }}"
            alt="Logo Loryane Essentielle"
            class="about-logo"
        >

        <h1 class="about-title">
            Loryane <span>Essentielle®</span>
        </h1>

        <p class="about-tagline">
            "Quand la lumière intérieure s’allie à la puissance de la nature"
        </p>

    </section>

    <!-- CONTENT -->
    <section class="about-container">

        <div class="about-card">

            <p>
                Loryane Essentielle propose des coffrets bien-être haut de gamme,
                conçus pour accompagner des moments de reconnexion intérieure.
            </p>

            <p>
                Chaque pack associe des éléments naturels soigneusement sélectionnés :
                pierres, huiles essentielles et objets rituels,
                afin de créer une expérience sensorielle unique.
            </p>

            <p>
                Pensés comme de véritables instants pour soi,
                ces coffrets allient, esthétique, simplicité et profondeur.
            </p>

        </div>

    </section>

{% endblock %}
