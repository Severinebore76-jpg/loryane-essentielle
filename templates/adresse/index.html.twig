{% extends 'base.html.twig' %}

{% block title %}Mes adresses{% endblock %}

{% block body %}

    <section class="address-container">

        <h1 class="address-title">Mes adresses</h1>

        <div class="address-list">

            {% for adresse in adresses %}
                <div class="address-item">

                    <!-- INFOS -->
                    <div class="address-info">
                        <h2>{{ adresse.prenom|capitalize }} {{ adresse.nom|upper }}</h2>

                        <p class="address-text">
                            {{ adresse.numero }} {{ adresse.typeVoie }} {{ adresse.nomVoie }}<br>
                            {{ adresse.codePostal }} {{ adresse.ville }}<br>
                            {{ adresse.pays }}<br>

                            <strong>
                                {% if adresse.type == 'livraison' %}
                                    Livraison
                                {% elseif adresse.type == 'facturation' %}
                                    Facturation
                                {% else %}
                                    Livraison & Facturation
                                {% endif %}
                            </strong>
                        </p>
                    </div>

                    <!-- ACTIONS -->
                    <div class="address-actions">

                        <a href="{{ path('app_adresse_edit', {id: adresse.id}) }}" class="address-btn">
                            Modifier
                        </a>

                        <form method="post"
                              action="{{ path('app_adresse_delete', {id: adresse.id}) }}">

                            <input type="hidden"
                                   name="_token"
                                   value="{{ csrf_token('delete' ~ adresse.id) }}">

                            <button type="submit" class="address-btn" formnovalidate>
                                Supprimer
                            </button>
                        </form>

                    </div>

                </div>
            {% else %}
                <p class="address-empty">Aucune adresse enregistrée.</p>
            {% endfor %}

        </div>

        <div class="address-footer">
            <a href="{{ path('app_adresse_new') }}" class="address-btn">
                Ajouter une adresse
            </a>
        </div>

        <div class="address-back">
            <a href="{{ path('app_profil') }}" class="btn-profile">
                ← Retour au profil
            </a>
        </div>

    </section>

{% endblock %}
