{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}

    {% if not app.user %}

        <h1>Connexion</h1>

        {% if error %}
            <div style="color:red;">
                Identifiants invalides
            </div>
        {% endif %}

        <form method="post">

            <label>Email</label><br>
            <input type="email" name="_username" value="{{ last_username }}" required><br><br>

            <label>Mot de passe</label><br>
            <input type="password" name="_password" required><br><br>

            <button type="submit">Se connecter</button>

        </form>

    {% else %}

        <p>Vous êtes déjà connecté.</p>

    {% endif %}

{% endblock %}
