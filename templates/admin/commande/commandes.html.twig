{% extends 'base.html.twig' %}

{% block title %}Commandes{% endblock %}

{% block body %}

    <section class="admin-container admin-commandes">

        <!-- HEADER -->
        <div class="admin-header">
            <div>
                <h1 class="admin-title">Commandes</h1>
                <p class="admin-subtitle">
                    Gestion des commandes clients
                </p>
            </div>
            <a href="{{ path('admin_dashboard') }}"
               class="btn btn-outline">
                ← Retour admin
            </a>
        </div>

        <!-- TOOLBAR -->
        <div class="admin-toolbar">
            <button id="admin-filter-toggle"
                    class="btn btn-outline">
                Filtres
            </button>
        </div>

        <!-- PANEL FILTRES -->
        <div id="admin-filter-panel"
             class="admin-filter-panel">
            <form method="get"
                  class="admin-filter-form">
                <div class="admin-form-group">
                    <label for="filter-id">
                        ID
                    </label>
                    <input id="filter-id"
                           type="number"
                           name="id"
                           value="{{ app.request.query.get('id') }}">
                </div>
                <div class="admin-form-group">
                    <label for="filter-client">
                        Client
                    </label>
                    <input id="filter-client"
                           type="text"
                           name="client"
                           value="{{ app.request.query.get('client') }}">
                </div>
                <div class="admin-form-group">
                    <label for="filter-statut">
                        Statut
                    </label>
                    <select id="filter-statut"
                            name="statut">
                        <option value="">
                            Tous
                        </option>
                        <option value="pending"
                            {% if app.request.query.get('statut') == 'pending' %}
                        selected
                            {% endif %}>
                            En attente
                        </option>
                        <option value="paid"
                            {% if app.request.query.get('statut') == 'paid' %}
                        selected
                            {% endif %}>
                            Payée
                        </option>
                    </select>
                </div>
                <div class="admin-form-group">
                    <label for="filter-date">
                        Date
                    </label>
                    <input id="filter-date"
                           type="date"
                           name="date"
                           value="{{ app.request.query.get('date') }}">
                </div>
                <div class="admin-form-group">
                    <label for="filter-min">
                        Montant min
                    </label>
                    <input id="filter-min"
                           type="number"
                           step="0.01"
                           name="min"
                           value="{{ app.request.query.get('min') }}">
                </div>
                <div class="admin-form-group">
                    <label for="filter-max">
                        Montant max
                    </label>
                    <input id="filter-max"
                           type="number"
                           step="0.01"
                           name="max"
                           value="{{ app.request.query.get('max') }}">
                </div>
                <button type="submit"
                        class="btn btn-main">
                    Appliquer
                </button>
            </form>
        </div>

        <!-- TABLE -->
        <div class="admin-card admin-table-card">
            <table class="admin-table">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Statut</th>
                    <th>Client</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for commande in commandes %}
                    <tr>
                        <td>
                            #{{ commande.id }}
                        </td>
                        <td>
                            {{ commande.date|date('d/m/Y') }}
                        </td>
                        <td>
                            {{ commande.total }} €
                        </td>
                        <td>
                            {% if commande.statut == 'pending' %}
                                <span class="status pending">
                                    En attente
                                </span>
                            {% elseif commande.statut == 'paid' %}
                                <span class="status paid">
                                    Payée
                                </span>
                            {% else %}
                                <span class="status">
                                    {{ commande.statut }}
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            {{ commande.utilisateur.email }}
                        </td>
                        <td>
                            <a href="{{ path('admin_commande_detail', {
                                id: commande.id
                            }) }}"
                               class="btn btn-outline btn-sm">
                                Voir
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6"
                            class="admin-empty">
                            Aucune commande
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
