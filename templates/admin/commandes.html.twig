{% extends 'base.html.twig' %}

{% block title %}Commandes{% endblock %}

{% block body %}

    <section class="admin-container">

        <!-- HEADER -->
        <div class="admin-header">

            <div>
                <h1 class="admin-title">Commandes</h1>
                <p class="admin-subtitle">Gestion des commandes clients</p>
            </div>

            <a href="{{ path('admin_dashboard') }}" class="btn btn-outline">
                ← Retour admin
            </a>
        </div>

        <!-- TOOLBAR FILTRES -->
        <div class="catalog-toolbar">
                <button id="filter-toggle" class="btn btn-outline">
                    Filtres
                </button>
        </div>

        <!-- PANEL FILTRES -->
        <div id="filter-panel" class="filter-panel">

            <form method="get">

                <div class="admin-form-group">
                    <label>ID</label>
                    <input type="number" name="id"
                           value="{{ app.request.query.get('id') }}">
                </div>

                <div class="admin-form-group">
                    <label>Client</label>
                    <input type="text" name="client"
                           value="{{ app.request.query.get('client') }}">
                </div>

                <div class="admin-form-group">
                    <label>Statut</label>
                    <select name="statut">
                        <option value="">Tous</option>
                        <option value="pending"
                                {% if app.request.query.get('statut') == 'pending' %}selected{% endif %}>
                            En attente
                        </option>
                        <option value="paid"
                                {% if app.request.query.get('statut') == 'paid' %}selected{% endif %}>
                            Payée
                        </option>
                    </select>
                </div>

                <div class="admin-form-group">
                    <label>Date</label>
                    <input type="date" name="date"
                           value="{{ app.request.query.get('date') }}">
                </div>

                <div class="admin-form-group">
                    <label>Montant min</label>
                    <input type="number" step="0.01" name="min"
                           value="{{ app.request.query.get('min') }}">
                </div>

                <div class="admin-form-group">
                    <label>Montant max</label>
                    <input type="number" step="0.01" name="max"
                           value="{{ app.request.query.get('max') }}">
                </div>

                <button type="submit" class="btn btn-main">
                    Appliquer
                </button>

            </form>

        </div>

        <!-- TABLE -->
        <div class="admin-card">

            <table class="admin-table">

                <thead>
                <tr>
                    <th>ID</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Statut</th>
                    <th>Client</th>
                    <th></th>
                </tr>
                </thead>

                <tbody>
                {% for commande in commandes %}
                    <tr>

                        <td>#{{ commande.id }}</td>

                        <td>{{ commande.date|date('d/m/Y') }}</td>

                        <td>{{ commande.total }} €</td>

                        <td>
                            {% if commande.statut == 'pending' %}
                                <span class="status pending">En attente</span>
                            {% elseif commande.statut == 'paid' %}
                                <span class="status paid">Payée</span>
                            {% else %}
                                <span class="status">{{ commande.statut }}</span>
                            {% endif %}
                        </td>

                        <td>{{ commande.utilisateur.email }}</td>

                        <td>
                            <a href="{{ path('admin_commande_detail', {id: commande.id}) }}"
                               class="btn btn-outline btn-sm">
                                Voir
                            </a>
                        </td>

                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">Aucune commande</td>
                    </tr>
                {% endfor %}
                </tbody>

            </table>

        </div>

    </section>

    <!-- JS TOGGLE FILTRES -->
    <script>

        document.addEventListener("DOMContentLoaded", function () {

            const btn = document.getElementById("filter-toggle");

            const panel = document.getElementById("filter-panel");

            if (btn && panel) {

                btn.addEventListener("click", function () {

                    if (panel.style.display === "block") {

                        panel.style.display = "none";

                    } else {

                        panel.style.display = "block";

                    }

                });

            }

        });

    </script>

{% endblock %}
