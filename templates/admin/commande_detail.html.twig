{% extends 'base.html.twig' %}

{% block body %}

    {% set statuts = {
        'pending': 'En attente',
        'paid': 'Payée',
        'shipped': 'Expédiée',
        'cancelled': 'Annulée'
    } %}

    <h1>Détail commande #{{ commande.id }}</h1>

    <p><strong>Date :</strong> {{ commande.date|date('d/m/Y') }}</p>
    <p><strong>Total :</strong> {{ commande.total }} €</p>
    <p>
        <strong>Statut :</strong>
        {{ statuts[commande.statut] ?? commande.statut }}
    </p>

    <h2>Produits</h2>

    <table>
        <tr>
            <th>Produit</th>
            <th>Quantité</th>
            <th>Prix</th>
        </tr>

        {% for ligne in commande.ligneCommandes %}
            <tr>
                <td>{{ ligne.produit.nom }}</td>
                <td>{{ ligne.quantite }}</td>
                <td>{{ ligne.prix }} €</td>
            </tr>
        {% endfor %}
    </table>

    <form method="post" action="{{ path('admin_commande_update_statut', {id: commande.id}) }}">
        <select name="statut">
            {% for key, label in statuts %}
                <option value="{{ key }}" {% if commande.statut == key %}selected{% endif %}>
                    {{ label }}
                </option>
            {% endfor %}
        </select>

        <button type="submit">Mettre à jour le statut</button>
    </form>

{% endblock %}
