<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Loryane{% endblock %}</title>

    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    <link rel="stylesheet" href="{{ asset('css/accueil.css') }}">
    <link rel="stylesheet" href="{{ asset('css/profil.css') }}">
    <link rel="stylesheet" href="{{ asset('css/about.css') }}">
    <link rel="stylesheet" href="{{ asset('css/catalogue.css') }}">
    <link rel="stylesheet" href="{{ asset('css/panier.css') }}">
    <link rel="stylesheet" href="{{ asset('css/produit.css') }}">

</head>
<body>

<header class="header">
    <div class="header-container">
        <nav class="nav">
            {% set route = app.request.attributes.get('_route') %}

            <a href="{{ path('app_home') }}"
               class="nav-btn {{ route == 'app_home' ? 'active' }}">
                Accueil
            </a>

            <a href="{{ path('app_produits') }}"
               class="nav-btn {{ route starts with 'app_produits' ? 'active' }}">
                Catalogue
            </a>

            <a href="{{ path('app_panier') }}"
               class="nav-btn {{ route starts with 'app_panier' ? 'active' }}">
                Mon panier
            </a>

            <a href="{{ path('app_profil') }}"
               class="nav-btn {{ route starts with 'app_profil' ? 'active' }}">
                Mon compte
            </a>

            <a href="{{ path('app_about') }}"
               class="nav-btn {{ route == 'app_about' ? 'active' }}">
                À propos
            </a>
        </nav>

        <div class="header-right">
            {% if app.user %}
                <a href="{{ path('app_logout') }}" class="icon">🔓</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="icon">🔒</a>
            {% endif %}
            <form action="{{ path('app_produits') }}" method="get" class="search-form">
                <input type="text" name="q" placeholder="Rechercher..." class="search-input">
                <button type="submit" class="icon">🔍</button>
            </form>
            <div class="lang-switch">
                <span class="lang active">Fr</span>
                <span class="lang">En</span>
                <span class="lang">Es</span>
            </div>
        </div>
    </div>
</header>

<div class="auth-bar">
    {% if app.user %}
        <strong>Connecté : {{ app.user.userIdentifier }}</strong>
        |
        <a href="{{ path('app_logout') }}">Se déconnecter</a>
    {% else %}
        <a href="{{ path('app_login') }}">Se connecter</a>
    {% endif %}
</div>

{% for message in app.flashes('success') %}
    <div class="flash flash-success">{{ message }}</div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="flash flash-error">{{ message }}</div>
{% endfor %}

{% if app.request.attributes.get('_route') != 'commande_detail' %}
    {% for message in app.flashes('order_success') %}
        <div class="flash flash-order">
            {{ message }}
        </div>
    {% endfor %}
{% endif %}

<!-- 🔥 WRAPPER GLOBAL -->
<div class="page-background">

    <main>
        {% block body %}{% endblock %}
    </main>

    <!-- ✅ FOOTER AU BON ENDROIT -->
    <footer class="footer">
        <div class="footer-container">
            <a href="{{ path('app_mentions') }}">Mentions légales</a>
            <a href="{{ path('app_cgv') }}">CGV</a>
            <a href="{{ path('app_contact') }}">Contact</a>
        </div>
    </footer>

</div>

</body>

</html>
