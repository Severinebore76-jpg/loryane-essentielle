<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {# HEADER NAVIGATION #}
        <header style="padding:10px; background:#ddd;">
            <nav>
                <a href="{{ path('app_home') }}">Accueil</a> |
                <a href="{{ path('app_produits') }}">Catalogue</a> |
                <a href="{{ path('app_panier') }}">Panier</a> |
                <a href="{{ path('app_profil') }}">Mon compte</a> |
                <a href="{{ path('app_about') }}">À propos</a>
            </nav>
        </header>
        {# BLOC AUTH #}
        <div style="padding:10px; background:#eee;">
            {% if app.user %}
                Connecté : {{ app.user.userIdentifier }}
                |
                <a href="{{ path('app_logout') }}">Se déconnecter</a>
            {% else %}
                <a href="{{ path('app_login') }}">Se connecter</a>
            {% endif %}
        </div>
        {# FLASH MESSAGES #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding:10px; margin:10px; border:1px solid red; color:red;">
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('success') %}
                <div style="color:green;">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        {# CONTENU #}
        {% block body %}{% endblock %}
    </body>
</html>
