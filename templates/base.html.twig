<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Loryane{% endblock %}</title>

    {% block importmap %} {{ importmap('app') }} {% endblock %}

    <link rel="stylesheet" href="{{ asset('css/variable.css') }}">
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    <link rel="stylesheet" href="{{ asset('css/accueil.css') }}">
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
    <link rel="stylesheet" href="{{ asset('css/profil.css') }}">
    <link rel="stylesheet" href="{{ asset('css/about.css') }}">
    <link rel="stylesheet" href="{{ asset('css/produit.css') }}">
    <link rel="stylesheet" href="{{ asset('css/panier.css') }}">
    <link rel="stylesheet" href="{{ asset('css/catalogue.css') }}">
</head>

<body>

<header class="header">
    <div class="header-container">

        {# MENU DYNAMIQUE #}
        {% set route = app.request.attributes.get('_route') %}
        {% set menu = [] %}

        {# COMMUN #}
        {% set menu = menu|merge([
            { label: 'Accueil', route: 'app_home', active: route == 'app_home' },
            { label: 'Catalogue', route: 'app_produits', active: route starts with 'app_produits' }
        ]) %}

        {# CLIENT UNIQUEMENT #}
        {% if not is_granted('ROLE_ADMIN') %}
            {% set menu = menu|merge([
                { label: 'Mon panier', route: 'app_panier', active: route starts with 'app_panier' },
                { label: 'Mon compte', route: 'app_profil', active: route starts with 'app_profil' },
                { label: 'À propos', route: 'app_about', active: route == 'app_about' }
            ]) %}
        {% endif %}

        {# ADMIN #}
        {% if is_granted('ROLE_ADMIN') %}
            {% set menu = menu|merge([
                { label: 'Admin', route: 'admin_dashboard', active: route starts with 'admin' }
            ]) %}
        {% endif %}

        <nav class="nav">
            {% for item in menu %}
                <a href="{{ path(item.route) }}"
                   class="nav-btn {{ item.active ? 'active' }}">
                    {{ item.label }}
                </a>
            {% endfor %}
        </nav>

        <div class="header-right">
            <form action="{{ path('app_produits') }}" method="get" class="search-form">
                <label for="search-input" class="sr-only">
                </label>
                <input id="search-input"
                       type="text"
                       name="q"
                       placeholder="Rechercher..."
                       class="search-input">
                <button type="submit" class="search-btn">🔍</button>
            </form>

            {% if app.user %}
                <a href="{{ path('app_logout') }}" class="header-icon">🔓</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="header-icon">🔒</a>
            {% endif %}

            <div class="lang-switch">
                <span class="lang-switch-item-active">Fr</span>
                <span class="lang-switch-item">En</span>
                <span class="lang-switch-item">Es</span>
            </div>
        </div>

    </div>
</header>

<div class="auth-bar">
    {% if app.user %}
        <strong>Connecté : {{ app.user.userIdentifier }}</strong>
        |
        <a href="{{ path('app_logout') }}">Se déconnecter</a>
    {% else %}
        <a href="{{ path('app_login') }}">Se connecter</a>
    {% endif %}
</div>

{% for message in app.flashes('success') %}
    <div class="flash flash-success">{{ message }}</div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="flash flash-error">{{ message }}</div>
{% endfor %}

{% if app.request.attributes.get('_route') != 'commande_detail' %}
    {% for message in app.flashes('order_success') %}
        <div class="flash flash-order">
            {{ message }}
        </div>
    {% endfor %}
{% endif %}

    <main>
        {% block body %}{% endblock %}
    </main>

    {% if not is_granted('ROLE_ADMIN') %}
    <footer class="footer">
        <div class="footer-container">
            <a href="{{ path('app_mentions') }}" >Mentions légales</a>
            <a href="{{ path('app_cgv') }}">CGV</a>
            <a href="{{ path('app_contact') }}">Contact</a>
        </div>
    </footer>
    {% endif %}

</body>
</html>
