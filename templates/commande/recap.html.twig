{% extends 'base.html.twig' %}

{% block title %}Récapitulatif commande{% endblock %}

{% block body %}

    <h1>Récapitulatif de commande</h1>

    <h2>Produits</h2>

    <ul>
        {% for item in panier %}
            <li>
                {{ item.produit.nom }} - {{ item.quantite }} x {{ item.produit.prix }} €
            </li>
        {% endfor %}
    </ul>

    <p><strong>Total : {{ total }} €</strong></p>

    <hr>

    <form method="post" action="{{ path('commande_create') }}">

        <h2>Choisir une adresse</h2>

        {% for adresse in adresses %}
            <div>
                <input type="radio" name="adresse_id" value="{{ adresse.id }}" required>
                {{ adresse.prenom }} {{ adresse.nom }} -
                {{ adresse.adresseComplete }},
                {{ adresse.codePostal }} {{ adresse.ville }}
            </div>
        {% endfor %}

        <br>

        <button type="submit">Confirmer la commande</button>

    </form>

{% endblock %}
