{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.id }}{% endblock %}

{% block body %}
    <!-- INFOS COMMANDE -->
    <section class="cart-container">

        <h1 class="cart-title order-title">
            Commande #{{ commande.id }}

            {% for message in app.flashes('order_success') %}
                <span class="order-badge">
            ✔ enregistrée
        </span>
            {% endfor %}
        </h1>
        <div class="cart-list">
            <div class="cart-item">

                <div class="cart-info">
                    <h2>Date</h2>
                    <p class="cart-date">
                        {{ commande.date|date('d/m/Y H:i') }}
                    </p>
                </div>

                <div class="cart-info">
                    <h2>Statut</h2>
                    <p class="cart-address">
                        {% set statutLabel = {
                            'pending': 'En attente',
                            'paid': 'Payée',
                            'shipped': 'Expédiée',
                            'cancelled': 'Annulée'
                        }[commande.statut] ?? commande.statut %}

                        <span class="status status-{{ commande.statut }}">
    {{ statutLabel }}
</span>
                    </p>
                </div>

                <div class="cart-total">
                    {{ commande.total|number_format(2, ',', ' ') }} €
                </div>

            </div>
        </div>

        <!-- PRODUITS -->
        <h2 class="cart-title" style="margin-top:40px;">Produits</h2>

        <div class="cart-list">

            {% for ligne in commande.ligneCommandes %}
                <div class="cart-item">

                    <!-- IMAGE -->
                    <div class="cart-image">
                        <img
                            src="{{ asset(ligne.produit.image ? 'uploads/' ~ ligne.produit.image : 'images/default.jpg') }}"
                            alt="{{ ligne.produit.nom }}"
                            onerror="this.onerror=null;this.src='{{ asset('images/default.jpg') }}';">
                    </div>

                    <!-- INFOS -->
                    <div class="cart-info">
                        <h2>{{ ligne.produit.nom }}</h2>
                        <p class="cart-price-unit">
                            {{ ligne.prix|number_format(2, ',', ' ') }} € / unité
                        </p>
                    </div>

                    <!-- QTE -->
                    <div class="cart-qty">
                        x {{ ligne.quantite }}
                    </div>

                    <!-- TOTAL -->
                    <div class="cart-total">
                        {{ (ligne.prix * ligne.quantite)|number_format(2, ',', ' ') }} €
                    </div>

                </div>
            {% endfor %}

        </div>

        <!-- 🔥 ADRESSE -->
        <h2 class="cart-title" style="margin-top:40px;">Adresse de livraison</h2>

        <div class="cart-list">
            <div class="cart-item">

                <div class="cart-info">
                    <p class="cart-address">
                        <strong>{{ commande.adresse.prenom }} {{ commande.adresse.nom }}</strong><br>
                     {{ commande.adresse.numero }} {{ commande.adresse.typeVoie }} {{ commande.adresse.nomVoie }}<br>
                        {{ commande.adresse.codePostal }} {{ commande.adresse.ville }}<br>
                        {{ commande.adresse.pays }}
                    </p>
                </div>

            </div>
        </div>

        <!-- TOTAL GLOBAL -->
        <div class="cart-footer">

            <div class="cart-total-global">
                Total : {{ commande.total|number_format(2, ',', ' ') }} €
            </div>

            <a href="{{ path('commande_list') }}" class="btn-validate">
                ← Retour
            </a>

        </div>

    </section>

{% endblock %}
