{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.id }}{% endblock %}

{% block body %}

    <section class="cart-container">

        <!-- INFOS COMMANDE -->
        <h1 class="cart-title order-title">
            Commande #{{ commande.id }}

            {% for message in app.flashes('order_success') %}
                <span class="order-badge">
                    ✔ enregistrée
                </span>
            {% endfor %}
        </h1>

        <div class="cart-list">

            <div class="cart-item">

                <!-- DATE -->
                <div class="cart-info">

                    <h2>Date</h2>

                    <p class="order-date">
                        {{ commande.date|date('d/m/Y H:i') }}
                    </p>

                </div>

                <!-- STATUT -->
                <div class="cart-info">

                    <h2>Statut</h2>

                    {% set statutLabel = {
                        'pending': 'En attente',
                        'paid': 'Payée',
                        'shipped': 'Expédiée',
                        'cancelled': 'Annulée'
                    }[commande.statut] ?? commande.statut %}

                    <span class="order-status status-{{ commande.statut }}">
                        {{ statutLabel }}
                    </span>

                </div>

                <!-- TOTAL -->
                <div class="cart-total">
                    {{ commande.total|number_format(2, ',', ' ') }} €
                </div>

            </div>

        </div>

        <!-- PRODUITS -->
        <h2 class="cart-title" style="margin-top: 40px;">
            Produits
        </h2>

        <div class="cart-list">

            {% for ligne in commande.ligneCommandes %}

                <div class="cart-item">

                    <!-- IMAGE -->
                    <div class="cart-image">

                        <img
                            src="{{ ligne.produit.image
                            ? asset('uploads/' ~ ligne.produit.image)
                            : asset('images/produit1.jpg') }}"
                            alt="{{ ligne.produit.nom }}"
                            data-fallback="{{ asset('images/produit1.jpg') }}"
                        >

                    </div>

                    <!-- INFOS -->
                    <div class="cart-info">

                        <h2>{{ ligne.produit.nom }}</h2>

                        <p class="cart-price-unit">
                            {{ ligne.prix|number_format(2, ',', ' ') }} € / unité
                        </p>

                    </div>

                    <!-- QUANTITÉ -->
                    <div class="cart-qty order-quantity">
                        x {{ ligne.quantite }}
                    </div>

                    <!-- TOTAL -->
                    <div class="cart-total">
                        {{ (ligne.prix * ligne.quantite)|number_format(2, ',', ' ') }} €
                    </div>

                </div>

            {% endfor %}

        </div>

        <!-- ADRESSE -->
        <h2 class="cart-title" style="margin-top: 40px;">
            Adresse de livraison
        </h2>

        <div class="cart-list">

            <div class="cart-item">

                <div class="cart-info">

                    <div class="order-address">

                        <strong>
                            {{ commande.adresse.prenom }}
                            {{ commande.adresse.nom }}
                        </strong>

                        <br>

                        {{ commande.adresse.numero }}
                        {{ commande.adresse.typeVoie }}
                        {{ commande.adresse.nomVoie }}

                        <br>

                        {{ commande.adresse.codePostal }}
                        {{ commande.adresse.ville }}

                        <br>

                        {{ commande.adresse.pays }}

                    </div>

                </div>

            </div>

        </div>

        <!-- TOTAL GLOBAL -->
        <div class="cart-footer">

            <div class="cart-total-global">
                Total : {{ commande.total|number_format(2, ',', ' ') }} €
            </div>

            <a href="{{ path('commande_list') }}" class="btn-profile">
                ← Retour
            </a>

        </div>

    </section>

{% endblock %}
